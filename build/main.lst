 133:Core/Src/main.c **** /**
 134:Core/Src/main.c ****   * @brief  TIM2 Interrupt Handler (b ve c şıkları)
 135:Core/Src/main.c ****   */
 136:Core/Src/main.c **** void HAL_TIM_PeriodElapsedCallback(TIM_HandleTypeDef *htim) {
 137:Core/Src/main.c ****     if (htim->Instance == TIM2) {
 138:Core/Src/main.c ****         timer_counter++;
 139:Core/Src/main.c **** 
 140:Core/Src/main.c ****         if (is_blinking) {
 141:Core/Src/main.c ****             // c şıkkı: blink_count kadar yan-sön döngüsü
 142:Core/Src/main.c ****             // (Her yan-sön 2 saniye sürer: 1sn ON, 1sn OFF)
 143:Core/Src/main.c ****             if (timer_counter <= (blink_count * 2)) {
 144:Core/Src/main.c ****                 HAL_GPIO_TogglePin(GPIOC, GPIO_PIN_13);
 145:Core/Src/main.c ****             } else {
 146:Core/Src/main.c ****                 // Blink bitti, 5 saniye sönük kalma evresine geç
 147:Core/Src/main.c ****                 is_blinking = 0;
ARM GAS  C:\Users\Bedirhan\AppData\Local\Temp\ccN6YkcL.s 			page 4


 148:Core/Src/main.c ****                 timer_counter = 0;
 149:Core/Src/main.c ****                 HAL_GPIO_WritePin(GPIOC, GPIO_PIN_13, GPIO_PIN_SET); // LED Kapalı (PC13 Pull-up)
 150:Core/Src/main.c ****             }
 151:Core/Src/main.c ****         } else {
 152:Core/Src/main.c ****             // 5 saniye sönük durma kontrolü
 153:Core/Src/main.c ****             if (timer_counter >= 5) {
 154:Core/Src/main.c ****                 is_blinking = 1;
 155:Core/Src/main.c ****                 timer_counter = 0;
 156:Core/Src/main.c ****             }
 157:Core/Src/main.c ****         }
 158:Core/Src/main.c ****     }
 159:Core/Src/main.c **** }
 160:Core/Src/main.c **** /* USER CODE END 4 */
