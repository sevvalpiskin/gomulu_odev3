  57:Core/Src/main.c ****   /* USER CODE BEGIN 2 */
  58:Core/Src/main.c ****   // 1. Yazılım başladığında Flash'tan değeri yükle (e şıkkı)
  59:Core/Src/main.c ****   blink_count = Flash_Read(flash_addr);
  60:Core/Src/main.c **** 
  61:Core/Src/main.c ****   // 2. Geçersiz değer kontrolü (f şıkkı: 0xFFFF veya menzil dışı ise 4 yap)
  62:Core/Src/main.c ****   if (blink_count < 4 || blink_count > 7) {
  63:Core/Src/main.c ****       blink_count = 4;
  64:Core/Src/main.c ****       Flash_Write(blink_count);
  65:Core/Src/main.c ****   }
  66:Core/Src/main.c **** 
  67:Core/Src/main.c ****   /* g — fabrika 4: Yalnızca güç verilirken buton basılıyken 3 sn tutulunca */
  68:Core/Src/main.c ****   if (HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_0) == GPIO_PIN_RESET) {
  69:Core/Src/main.c ****       uint32_t boot_press_t0 = HAL_GetTick();
  70:Core/Src/main.c ****       while (HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_0) == GPIO_PIN_RESET) {
  71:Core/Src/main.c ****           if ((HAL_GetTick() - boot_press_t0) >= 3000U) {
  72:Core/Src/main.c ****               blink_count = 4;
  73:Core/Src/main.c ****               Flash_Write(blink_count);
  74:Core/Src/main.c ****               while (HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_0) == GPIO_PIN_RESET) { }
  75:Core/Src/main.c ****               break;
  76:Core/Src/main.c ****           }
  77:Core/Src/main.c ****       }
  78:Core/Src/main.c ****   }
  79:Core/Src/main.c **** 
  80:Core/Src/main.c ****   /* TIM2: flash ve isteğe bağlı fabrika adımı bittikten sonra */
  81:Core/Src/main.c ****   HAL_TIM_Base_Start_IT(&htim2);
  82:Core/Src/main.c ****   s_next_button_ms = HAL_GetTick() + 400U;
  83:Core/Src/main.c ****   /* USER CODE END 2 */
  84:Core/Src/main.c **** 
  85:Core/Src/main.c ****   /* Infinite loop */
  86:Core/Src/main.c ****   /* USER CODE BEGIN WHILE */
  87:Core/Src/main.c ****   while (1)
  88:Core/Src/main.c ****   {
  89:Core/Src/main.c ****     /* Buton: güvenilir serbest = HIGH (pull-up); cooldown ile çift sayım yok */
  90:Core/Src/main.c ****     if (HAL_GetTick() >= s_next_button_ms
ARM GAS  C:\Users\Bedirhan\AppData\Local\Temp\ccN6YkcL.s 			page 3


  91:Core/Src/main.c ****         && HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_0) == GPIO_PIN_RESET)
  92:Core/Src/main.c ****     {
  93:Core/Src/main.c ****         uint32_t press_start = HAL_GetTick();
  94:Core/Src/main.c **** 
  95:Core/Src/main.c ****         /* Çalışırken: basılı kalma süresi önemli değil; bırakınca en fazla +1 (d) */
  96:Core/Src/main.c ****         while (HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_0) == GPIO_PIN_RESET) { }
  97:Core/Src/main.c **** 
  98:Core/Src/main.c ****         uint32_t duration = HAL_GetTick() - press_start;
  99:Core/Src/main.c ****         /* Bırakma sıçraması geçsin */
 100:Core/Src/main.c ****         for (uint32_t t0 = HAL_GetTick(); (HAL_GetTick() - t0) < 30U; )
 101:Core/Src/main.c ****         {
 102:Core/Src/main.c ****             if (HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_0) != GPIO_PIN_RESET)
 103:Core/Src/main.c ****             {
 104:Core/Src/main.c ****                 break;
 105:Core/Src/main.c ****             }
 106:Core/Src/main.c ****         }
 107:Core/Src/main.c **** 
 108:Core/Src/main.c ****         if (HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_0) == GPIO_PIN_RESET)
 109:Core/Src/main.c ****         {
 110:Core/Src/main.c ****             continue;
 111:Core/Src/main.c ****         }
 112:Core/Src/main.c **** 
 113:Core/Src/main.c ****         if (duration > 50U)
 114:Core/Src/main.c ****         {
 115:Core/Src/main.c ****             blink_count++;
 116:Core/Src/main.c ****             if (blink_count > 7)
 117:Core/Src/main.c ****             {
 118:Core/Src/main.c ****                 blink_count = 4;
 119:Core/Src/main.c ****             }
 120:Core/Src/main.c ****             Flash_Write(blink_count);
 121:Core/Src/main.c ****             s_next_button_ms = HAL_GetTick() + 350U;
 122:Core/Src/main.c ****         }
 123:Core/Src/main.c ****         else
 124:Core/Src/main.c ****         {
 125:Core/Src/main.c ****             s_next_button_ms = HAL_GetTick() + 50U;
 126:Core/Src/main.c ****         }
 127:Core/Src/main.c ****     }
 128:Core/Src/main.c ****     /* USER CODE END WHILE */
 129:Core/Src/main.c ****   }
 130:Core/Src/main.c **** }
